# TensorFlow (CPU only)
CUDA_VISIBLE_DEVICES=-1
TF_CPP_MIN_LOG_LEVEL=3
TF_ENABLE_ONEDNN_OPTS=0

# API
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# App config
MDL_MAX_TRAINING_MINUTES=30
MDL_MAX_UPLOAD_MB=500
MDL_TEMP_DIR=/tmp/mdl_workdir
WORKSPACE_ROOT=/tmp/mdl_workdir

# Redis (leave empty to use in-memory fallback)
REDIS_URL=redis://localhost:6379/0

# Auth / JWT — REQUIRED at boot. Generate with: openssl rand -hex 32
# The API will refuse to start if this is empty, contains "change-me",
# or is shorter than 32 characters.
JWT_SECRET=

# Deployment environment: "production" disables /docs and tightens /metrics
ENVIRONMENT=development
# IPs allowed to scrape /metrics in production (comma-separated). Empty=disabled.
METRICS_ALLOWED_IPS=

# Monitoring (optional)
SENTRY_DSN=
LOG_LEVEL=INFO

# Session
SESSION_TTL_SECONDS=7200
