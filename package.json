{
  "name": "machine-learning-traffic-redressement-platform",
  "description": "Plateforme ML full-stack de redressement de debits routiers.",
  "private": true,
  "license": "MIT",
  "homepage": "https://Trafic-Tool.anbri-tools-ia.online",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anbsamsam17/machine-learning-traffic-redressement-platform.git"
  },
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "docker:up": "docker compose -f infra/docker-compose.yml up --build",
    "docker:down": "docker compose -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "turbo": "^2.9.18"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "playwright-core": "^1.60.0"
  }
}
