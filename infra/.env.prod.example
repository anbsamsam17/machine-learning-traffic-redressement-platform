# infra/.env.prod.example
# Copy to `infra/.env.prod` then fill values. `.env.prod` is gitignored.
# chmod 600 .env.prod after editing.
#
# Usage:
#   cp infra/.env.prod.example infra/.env.prod
#   JWT=$(openssl rand -hex 32) && sed -i "s|^JWT_SECRET=.*$|JWT_SECRET=${JWT}|" infra/.env.prod
#   chmod 600 infra/.env.prod
#   docker compose -f infra/docker-compose.prod.yml --env-file infra/.env.prod up -d

# === REQUIRED — compose will refuse to start without it ===
# Generate with:  openssl rand -hex 32
# Must be 32+ chars, must NOT contain the substring "change-me" (config.py validator).
JWT_SECRET=

# === Image tag deployed (overridden by CI step with ${{ github.sha }}) ===
IMAGE_TAG=latest

# === Runtime ===
ENVIRONMENT=production
LOG_LEVEL=INFO

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Storage ===
# Host path mounted into the api container at /data/mdl_workdir.
# Must live on a persistent block volume (NOT /tmp).
HOST_WORKSPACE_ROOT=/data/mdl_workdir
WORKSPACE_ROOT=/data/mdl_workdir

# === Sessions / quotas ===
SESSION_TTL_SECONDS=7200
MAX_UPLOAD_MB=500
MAX_TRAINING_MINUTES=60

# === CORS — keep aligned with the public domain ===
CORS_ORIGINS=https://Trafic-Tool.anbri-tools-ia.online

# === Public URL injected into Next.js at build time (used by web image build args) ===
NEXT_PUBLIC_API_URL=https://Trafic-Tool.anbri-tools-ia.online

# === TensorFlow tuning for ARM CPU-only ===
CUDA_VISIBLE_DEVICES=-1
TF_CPP_MIN_LOG_LEVEL=3
TF_XLA_FLAGS=--tf_xla_enable_xla_devices=false

# === Observability (optional but recommended) ===
# Create a free Sentry project at https://sentry.io and paste the DSN here.
SENTRY_DSN=
